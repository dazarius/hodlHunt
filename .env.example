# Required
HODL_KEYPAIR=your_base58_keypair

# RPC (optional)
HODL_RPC=https://api.mainnet-beta.solana.com

# Transaction settings (optional)
HODL_CU_LIMIT=200000
HODL_CU_PRICE=375000

# Scheduler (optional)
HODL_FEED_PERIOD=7
HODL_MARK_WINDOW=24
HODL_MIN_SOL=0.1
HODL_MAX_TARGETS=5

# Telegram notifications (optional)
HODL_TG_TOKEN=
HODL_TG_CHAT=

# Donate (optional)
HODL_DONATE_ENABLED=0
HODL_DONATE_ADDRESS=
